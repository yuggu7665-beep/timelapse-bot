# Telegram Bot Token from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# LongCat API Key (OpenAI-compatible)
OPENAI_API_KEY=your_longcat_api_key_here

# LongCat API Base URL
OPENAI_BASE_URL=https://api.longcat.chat/openai

# Model to use (LongCat-Flash-Chat, LongCat-Flash-Thinking, etc.)
OPENAI_MODEL=LongCat-Flash-Chat

# Maximum number of messages to keep per user
MAX_HISTORY_PER_USER=20

# Webhook URL (must be HTTPS in production)
# PythonAnywhere format: https://yourusername.pythonanywhere.com/webhook
WEBHOOK_URL=https://yourusername.pythonanywhere.com/webhook